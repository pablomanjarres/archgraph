  "flows": [
    {
      "id": "flow-mcp-media-generation",
      "name": "AI Media Generation via MCP",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-claudecode-mcp",
          "description": "Claude Code calls forge_generate_image with a prompt"
        },
        {
          "order": 2,
          "connectionId": "conn-mcp-api",
          "description": "MCP server proxies to POST /api/generate/image"
        },
        {
          "order": 3,
          "connectionId": "conn-api-keychain",
          "description": "API resolves the purpose-routed Gemini key from the keychain"
        },
        {
          "order": 4,
          "connectionId": "conn-api-gemini",
          "description": "API calls Gemini (Imagen) and writes the image to the generated dir"
        },
        {
          "order": 5,
          "connectionId": "conn-api-json",
          "description": "API upserts the media record into media.json"
        },
        {
          "order": 6,
          "connectionId": "conn-api-wshub",
          "description": "API broadcasts a media_created event to subscribers"
        }
      ]
    },
    {
      "id": "flow-render-remotion",
      "name": "Render a Remotion Demo Video",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-operator-dashboard",
          "description": "Operator clicks Render on a repo template"
        },
        {
          "order": 2,
          "connectionId": "conn-dashboard-api",
          "description": "Dashboard POSTs /api/templates/:id/render-repo"
        },
        {
          "order": 3,
          "connectionId": "conn-api-remotionmgr",
          "description": "API invokes the Remotion manager for the chosen composition"
        },
        {
          "order": 4,
          "connectionId": "conn-remotionmgr-remotion",
          "description": "Manager spawns `npx remotion render` in the Remotion project"
        },
        {
          "order": 5,
          "connectionId": "conn-remotionmgr-mediafs",
          "description": "Rendered mp4 is versioned and promoted to current.mp4 in the media root"
        },
        {
          "order": 6,
          "connectionId": "conn-api-wshub",
          "description": "API streams render progress and template_updated over WS"
        }
      ]
    },
    {
      "id": "flow-ai-compose-template",
      "name": "AI-Compose a New Remotion Template",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-operator-dashboard",
          "description": "Operator submits a prompt in Templates AI Create"
        },
        {
          "order": 2,
          "connectionId": "conn-dashboard-api",
          "description": "Dashboard POSTs /api/templates/ai-create"
        },
        {
          "order": 3,
          "connectionId": "conn-api-composer",
          "description": "API hands the prompt to the Gemini composer"
        },
        {
          "order": 4,
          "connectionId": "conn-composer-skills",
          "description": "Composer loads relevant SKILL.md context"
        },
        {
          "order": 5,
          "connectionId": "conn-composer-gemini",
          "description": "Composer requests structured component code from Gemini"
        },
        {
          "order": 6,
          "connectionId": "conn-api-json",
          "description": "API registers the generated template in templates.json"
        }
      ]
    },
    {
      "id": "flow-codex-agent-task",
      "name": "Launch a Codex Agent Task",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-operator-dashboard",
          "description": "Operator launches an agent task from the Agents page"
        },
        {
          "order": 2,
          "connectionId": "conn-dashboard-api",
          "description": "Dashboard POSTs /api/tasks/launch with provider=codex"
        },
        {
          "order": 3,
          "connectionId": "conn-api-codex",
          "description": "API spawns the Codex CLI (codex exec --json)"
        },
        {
          "order": 4,
          "connectionId": "conn-api-wshub",
          "description": "API streams agent stdout over WS as it runs"
        },
        {
          "order": 5,
          "connectionId": "conn-api-json",
          "description": "API persists task output and final status to tasks.json"
        }
      ]
    }
  ]
