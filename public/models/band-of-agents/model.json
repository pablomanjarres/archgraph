  "flows": [
    {
      "id": "flow-review",
      "name": "Pods Review Negotiation",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-marketer-web",
          "description": "Marketer submits a campaign material for review in the portal"
        },
        {
          "order": 2,
          "connectionId": "conn-web-server",
          "description": "Portal POSTs the asset to the review API"
        },
        {
          "order": 3,
          "connectionId": "conn-server-board",
          "description": "Server dispatches it to the blackboard-pods engine"
        },
        {
          "order": 4,
          "connectionId": "conn-board-perception",
          "description": "Board runs the vision and speech pre-pass on the material"
        },
        {
          "order": 5,
          "connectionId": "conn-board-agents",
          "description": "Board fans the asset out to the three specialist pods"
        },
        {
          "order": 6,
          "connectionId": "conn-agents-router",
          "description": "Each reviewer calls its per-role model to reason"
        },
        {
          "order": 7,
          "connectionId": "conn-agents-band",
          "description": "Reviewers file findings and debate conflicts in the room"
        },
        {
          "order": 8,
          "connectionId": "conn-band-bandai",
          "description": "Findings and one-round rebuttals flow over the Band SDK"
        },
        {
          "order": 9,
          "connectionId": "conn-server-filestore",
          "description": "The verdict and full event stream are persisted"
        }
      ]
    },
    {
      "id": "flow-escalation",
      "name": "Human Escalation and Remediation Loop",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-agents-band",
          "description": "The Risk Adjudicator posts a report and asks the human to approve a fix"
        },
        {
          "order": 2,
          "connectionId": "conn-server-filestore",
          "description": "The escalation and blocking findings are persisted"
        },
        {
          "order": 3,
          "connectionId": "conn-compliance-web",
          "description": "The Compliance Lead opens the escalation in the console"
        },
        {
          "order": 4,
          "connectionId": "conn-web-server",
          "description": "Approves the fix via the decision endpoint"
        },
        {
          "order": 5,
          "connectionId": "conn-server-board",
          "description": "Server drives the approved remediation cycle on the board"
        },
        {
          "order": 6,
          "connectionId": "conn-agents-router",
          "description": "Remediation rewrites the copy and regenerates a Nano Banana image"
        },
        {
          "order": 7,
          "connectionId": "conn-router-aiml",
          "description": "The image regeneration runs on AIML (Vertex fallback)"
        },
        {
          "order": 8,
          "connectionId": "conn-agents-band",
          "description": "Remediation posts the new copy and image and recommits for re-review"
        }
      ]
    },
    {
      "id": "flow-relay",
      "name": "Live Band Room Relay",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-judge-web",
          "description": "A viewer opens the live board and posts a question"
        },
        {
          "order": 2,
          "connectionId": "conn-web-server",
          "description": "Portal sends the message to the rooms API"
        },
        {
          "order": 3,
          "connectionId": "conn-server-band",
          "description": "The intake relay drives the Band adapter to post it"
        },
        {
          "order": 4,
          "connectionId": "conn-band-bandai",
          "description": "The message appears in the real Band.ai room for every agent"
        }
      ]
    }
  ]
