  "flows": [
    {
      "id": "flow-intake-web",
      "name": "Citizen Intake (Web Form)",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-web-edge-intake",
          "description": "Citizen submits the form; the web app POSTs it to the intake edge function"
        },
        {
          "order": 2,
          "connectionId": "conn-edge-intake-orchestrator",
          "description": "The edge function invokes the intake-agent orchestrator"
        },
        {
          "order": 3,
          "connectionId": "conn-intake-habeas",
          "description": "PII is redacted into raw / display / llm_text forms"
        },
        {
          "order": 4,
          "connectionId": "conn-intake-classifier",
          "description": "The classifier extracts tipo, secretaria, comuna and tags"
        },
        {
          "order": 5,
          "connectionId": "conn-classifier-anthropic",
          "description": "Classification runs against the Claude messages API"
        },
        {
          "order": 6,
          "connectionId": "conn-intake-deadline",
          "description": "The priority engine computes the legal business-day deadline"
        },
        {
          "order": 7,
          "connectionId": "conn-edge-intake-supabase",
          "description": "The edge function inserts pqr + pqr_events under the service role"
        },
        {
          "order": 8,
          "connectionId": "conn-edge-intake-indexer",
          "description": "A fire-and-forget indexing job is enqueued"
        }
      ]
    },
    {
      "id": "flow-intake-n8n",
      "name": "Citizen Intake (n8n Portal Workflow)",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-landing-n8n",
          "description": "The portal POSTs the PQRSD to the n8n webhook /pqrs/intake"
        },
        {
          "order": 2,
          "connectionId": "conn-n8n-supabase",
          "description": "The n8n workflow classifies with Gemini agents and inserts pqr + pqr_events"
        },
        {
          "order": 3,
          "connectionId": "conn-n8n-indexer",
          "description": "n8n calls the pqr-nella-indexer edge function"
        },
        {
          "order": 4,
          "connectionId": "conn-indexer-rag",
          "description": "The indexer renders the PQR as a Nella doc"
        },
        {
          "order": 5,
          "connectionId": "conn-rag-nella",
          "description": "The RAG client indexes it into the omega-pqr-corpus bucket"
        }
      ]
    },
    {
      "id": "flow-officer-queue",
      "name": "Officer Triage & Deadline",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-funcionario-workbench",
          "description": "The officer opens the juridical queue in the workbench"
        },
        {
          "order": 2,
          "connectionId": "conn-workbench-auth",
          "description": "The workbench authenticates the officer via Supabase SSR"
        },
        {
          "order": 3,
          "connectionId": "conn-workbench-db",
          "description": "The workbench reads the tenant PQR queue with the operational client"
        },
        {
          "order": 4,
          "connectionId": "conn-db-supabase",
          "description": "The client SET ROLE app_operational and RLS filters rows by tenant_id"
        },
        {
          "order": 5,
          "connectionId": "conn-workbench-deadline",
          "description": "The deadline engine shows remaining business days and any extension"
        }
      ]
    },
    {
      "id": "flow-transparencia",
      "name": "Public Transparency View",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-public-web",
          "description": "A member of the public opens /transparencia"
        },
        {
          "order": 2,
          "connectionId": "conn-web-db",
          "description": "The web app reads aggregated PQR stats by comuna and secretaria"
        },
        {
          "order": 3,
          "connectionId": "conn-db-supabase",
          "description": "The operational client queries the transparency views under RLS"
        }
      ]
    }
  ]
}