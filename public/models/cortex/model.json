  "flows": [
    {
      "id": "flow-claude-mcp-write",
      "name": "Claude Reads/Writes via MCP",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-claude-mcp",
          "description": "Claude calls a Cortex MCP tool (e.g. toggle_habit)"
        },
        {
          "order": 2,
          "connectionId": "conn-mcp-webapi",
          "description": "MCP server proxies the call to localhost:3456 /api/data"
        },
        {
          "order": 3,
          "connectionId": "conn-webapi-crypto",
          "description": "Web API routes the write through the encryption layer"
        },
        {
          "order": 4,
          "connectionId": "conn-crypto-keychain",
          "description": "Crypto loads the 32-byte master key from the Keychain"
        },
        {
          "order": 5,
          "connectionId": "conn-crypto-files",
          "description": "Data is sealed with AES-256-GCM into the local data file"
        }
      ]
    },
    {
      "id": "flow-founder-metrics",
      "name": "Founder Metrics Refresh",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-operator-renderer",
          "description": "Operator opens the Founder page"
        },
        {
          "order": 2,
          "connectionId": "conn-renderer-main",
          "description": "Renderer requests fresh stats over IPC"
        },
        {
          "order": 3,
          "connectionId": "conn-main-integrations",
          "description": "Main invokes the integration fetchers"
        },
        {
          "order": 4,
          "connectionId": "conn-integrations-github",
          "description": "Pulls commits, PRs & streak from GitHub"
        },
        {
          "order": 5,
          "connectionId": "conn-integrations-lemon",
          "description": "Pulls MRR & subscriptions from Lemon Squeezy"
        },
        {
          "order": 6,
          "connectionId": "conn-integrations-vercel",
          "description": "Pulls deployments & analytics from Vercel"
        }
      ]
    },
    {
      "id": "flow-opportunity-radar",
      "name": "Weekly Opportunity Radar (injection-safe)",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-launchd-radar",
          "description": "launchd fires the weekly radar job"
        },
        {
          "order": 2,
          "connectionId": "conn-radar-limavm",
          "description": "Scrapes X/Reddit/Devpost feeds via Apify on the Lima VM (untrusted output to a file)"
        },
        {
          "order": 3,
          "connectionId": "conn-radar-claude",
          "description": "Tool-less `claude -p` classifies & scores hits against the profile"
        },
        {
          "order": 4,
          "connectionId": "conn-radar-webapi",
          "description": "Validated, deduped survivors are POSTed to the Cortex store"
        },
        {
          "order": 5,
          "connectionId": "conn-webapi-crypto",
          "description": "Opportunities are sealed into the encrypted store"
        }
      ]
    },
    {
      "id": "flow-phone-tailscale",
      "name": "Phone Access over Tailscale",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-operator-webapi",
          "description": "Operator opens the :3456 PWA from phone over Tailscale"
        },
        {
          "order": 2,
          "connectionId": "conn-renderer-webapi",
          "description": "The served renderer calls /api/data"
        },
        {
          "order": 3,
          "connectionId": "conn-webapi-crypto",
          "description": "Web API decrypts the requested keys"
        },
        {
          "order": 4,
          "connectionId": "conn-crypto-files",
          "description": "Reads the plaintext back from the encrypted data files"
        }
      ]
    }
  ]
