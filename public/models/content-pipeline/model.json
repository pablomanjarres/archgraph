  "flows": [
    {
      "id": "flow-script-pack",
      "name": "Script Pack Generation",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-claudecode-api",
          "description": "Claude Code /script-pack pulls pipeline state and voice context via the REST API"
        },
        {
          "order": 2,
          "connectionId": "conn-api-obsidian",
          "description": "API server delegates to Obsidian Sync to load voice anchors"
        },
        {
          "order": 3,
          "connectionId": "conn-obsidian-marsvault",
          "description": "Obsidian Sync reads voice-anchor markdown from the Mars vault"
        },
        {
          "order": 4,
          "connectionId": "conn-api-json",
          "description": "Approved scripts are written back as scripted-status video records in the JSON store"
        }
      ]
    },
    {
      "id": "flow-post-sync",
      "name": "Post Draft to Vault",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-operator-webui",
          "description": "Operator edits a post in the dashboard"
        },
        {
          "order": 2,
          "connectionId": "conn-webui-api",
          "description": "SPA PATCHes the post through the REST API"
        },
        {
          "order": 3,
          "connectionId": "conn-api-obsidian",
          "description": "API server delegates to Obsidian Sync"
        },
        {
          "order": 4,
          "connectionId": "conn-obsidian-marsvault",
          "description": "Post is written as markdown into the Mars vault"
        },
        {
          "order": 5,
          "connectionId": "conn-obsidian-icloud",
          "description": "Content is mirrored to iCloud for cross-device access"
        }
      ]
    },
    {
      "id": "flow-watchlist-radar",
      "name": "Watchlist Radar",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-operator-webui",
          "description": "Operator adds a handle to the tiered watchlist"
        },
        {
          "order": 2,
          "connectionId": "conn-webui-api",
          "description": "SPA POSTs to /api/watchlist"
        },
        {
          "order": 3,
          "connectionId": "conn-api-watchlist",
          "description": "API server delegates to the Watchlist Radar component"
        },
        {
          "order": 4,
          "connectionId": "conn-watchlist-supabase",
          "description": "Handle is upserted into the Supabase watchlist_handles table"
        },
        {
          "order": 5,
          "connectionId": "conn-vm-supabase",
          "description": "The VM watchlist-radar worker reads the handle and begins polling X/LinkedIn"
        }
      ]
    },
    {
      "id": "flow-vm-control",
      "name": "Worker Pool Control",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-operator-webui",
          "description": "Operator opens the Ops page and starts the drafter pool"
        },
        {
          "order": 2,
          "connectionId": "conn-webui-api",
          "description": "SPA calls /api/openclaw/pool/drafter/start"
        },
        {
          "order": 3,
          "connectionId": "conn-api-vmadmin",
          "description": "API server delegates to the VM Admin Proxy"
        },
        {
          "order": 4,
          "connectionId": "conn-vmadmin-vm",
          "description": "Proxy calls the OpenClaw admin-control API to start the pool over Tailscale"
        }
      ]
    }
  ]
