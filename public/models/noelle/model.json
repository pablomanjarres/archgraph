  "flows": [
    {
      "id": "flow-lead-to-draft",
      "name": "Lead becomes an approvable draft",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-xintern-apify",
          "description": "X intern discovery polls Apify for tweets from watchlisted handles"
        },
        {
          "order": 2,
          "connectionId": "conn-xintern-cloudsql",
          "description": "Discovery upserts net-new rows into noelle.leads"
        },
        {
          "order": 3,
          "connectionId": "conn-xintern-runtime",
          "description": "The drafter routes the lead through callAgentModel with budget caps"
        },
        {
          "order": 4,
          "connectionId": "conn-runtime-nella",
          "description": "Runtime fetches voice anchors from the mars-pablo workspace"
        },
        {
          "order": 5,
          "connectionId": "conn-runtime-codex",
          "description": "Codex gpt-5 generates candidate replies (empathetic, technical, contrarian)"
        },
        {
          "order": 6,
          "connectionId": "conn-xintern-apivm",
          "description": "The drafter POSTs the drafts (HMAC-signed) to /api/outbound"
        },
        {
          "order": 7,
          "connectionId": "conn-apivm-cloudsql",
          "description": "The API inserts noelle.drafts and a pending noelle.approvals row"
        }
      ]
    },
    {
      "id": "flow-approve-send",
      "name": "Operator approves and sends a draft",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-operator-dashboard",
          "description": "Operator clicks Send on a pending draft in the approvals inbox"
        },
        {
          "order": 2,
          "connectionId": "conn-dashboard-supabase",
          "description": "Dashboard middleware verifies the Supabase JWT via JWKS and extracts sub"
        },
        {
          "order": 3,
          "connectionId": "conn-dashboard-apivm",
          "description": "Dashboard forwards the request (Bearer JWT) to the API send route"
        },
        {
          "order": 4,
          "connectionId": "conn-apivm-cloudsql",
          "description": "API marks the draft, lead, and approval as sent after assertOrgMember"
        },
        {
          "order": 5,
          "connectionId": "conn-apivm-xapi",
          "description": "API posts the approved reply to X via bird cookies"
        }
      ]
    },
    {
      "id": "flow-sibling-draft",
      "name": "Draft-only sibling intern proposes engagement",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-linkedin-apify",
          "description": "Lyra's discovery fetches new posts from watchlisted LinkedIn connections via Apify"
        },
        {
          "order": 2,
          "connectionId": "conn-linkedin-runtime",
          "description": "The classifier and drafter route through callAgentModel"
        },
        {
          "order": 3,
          "connectionId": "conn-runtime-vertex",
          "description": "Gemini Flash grades the lead as in-ICP; Claude Sonnet is the drafting fallback"
        },
        {
          "order": 4,
          "connectionId": "conn-runtime-cloudsql",
          "description": "The draft-only reply/DM is persisted to noelle.* for human approval"
        }
      ]
    },
    {
      "id": "flow-spend-cap",
      "name": "Spend is metered and capped",
      "steps": [
        {
          "order": 1,
          "connectionId": "conn-xintern-runtime",
          "description": "Every agent LLM call goes through callAgentModel, which runs the budget pre-check"
        },
        {
          "order": 2,
          "connectionId": "conn-runtime-codex",
          "description": "Under cap the call proceeds to Codex; otherwise BudgetExceededError is thrown"
        },
        {
          "order": 3,
          "connectionId": "conn-runtime-cloudsql",
          "description": "callAgentModel records the call cost into noelle.llm_calls"
        },
        {
          "order": 4,
          "connectionId": "conn-dashboard-cloudsql",
          "description": "The dashboard reads the aggregated noelle.org_spend_month for the cost view"
        }
      ]
    }
  ]
}